---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Privacy Policy | AppealAirportPCN.co.uk";
const description = "Privacy policy for AppealAirportPCN.co.uk — an independent informational website providing free public information relating to airport drop-off charge appeals.";
const canonical = "https://appealairportpcn.co.uk/privacy/";
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <nav class="breadcrumb">
    <div class="wrap">
      <a href="/">Home</a><span>›</span>
      <a href="/privacy/">Privacy Policy</a>
    </div>
  </nav>

  <main>
    <div class="wrap">
      <div class="privacy-page">

        <h1>Privacy Policy</h1>
        <p class="privacy-updated">Last updated: 21 April 2026</p>

        <p>Appeal Airport PCN is an independent informational website providing free public information relating to airport drop-off charge appeals.</p>

        <h2>Information We Collect</h2>
        <p>This website does not require users to register, create accounts, submit forms, or provide personal information directly.</p>
        <p>As with most websites, limited technical information may be processed automatically when you visit the site, including standard server or network information such as IP address, browser type, device information, and access times, where necessary for website delivery, security, and performance.</p>

        <h2>Hosting and Analytics</h2>
        <p>This website is hosted by Cloudflare Pages and uses Cloudflare Web Analytics to measure aggregate website usage, such as page views, referral sources, and general traffic trends.</p>
        <p>Cloudflare Web Analytics is used solely to understand website performance and improve the information provided. It is not used for advertising, profiling, or personalised marketing.</p>
        <p>For more information, please refer to <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer">Cloudflare's own privacy information</a>.</p>

        <h2>Cookies</h2>
        <p>This website does not intentionally use advertising or tracking cookies.</p>
        <p>However, strictly necessary technical cookies or similar technologies may be used by infrastructure providers where required for site operation or security.</p>

        <h2>How Information Is Used</h2>
        <p>Any limited technical information processed through hosting or analytics services is used only to:</p>
        <ul>
          <li>operate and secure the website</li>
          <li>monitor performance and reliability</li>
          <li>understand aggregate usage trends</li>
          <li>improve website content and accessibility</li>
        </ul>

        <h2>Third-Party Services</h2>
        <p>This website may rely on third-party service providers, including:</p>
        <ul>
          <li>Cloudflare (hosting, security, and analytics)</li>
          <li>Google (search performance tools, including Google Search Console)</li>
        </ul>

        <h2>Data Protection</h2>
        <p>This website is intended to minimise data collection and does not knowingly collect personal data beyond limited technical data processed as part of standard website operation.</p>

        <h2>Your Rights</h2>
        <p>If you are based in the United Kingdom, you may have rights in relation to personal data under applicable data protection law, including the right to request information about data processing, where applicable.</p>
        <p>Privacy-related enquiries may be sent to: <a href="mailto:privacy@appealairportpcn.co.uk">privacy@appealairportpcn.co.uk</a></p>

        <h2>Changes to This Policy</h2>
        <p>This Privacy Policy may be updated from time to time. Any changes will be posted on this page.</p>

      </div>
    </div>
  </main>

</BaseLayout>
