---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — Appeal Airport PCN">
  <main>
    <div style="text-align: center; padding: 4rem 2rem;">
      <h1>404 — Page Not Found</h1>
      <p style="font-size: 1.1rem; margin-bottom: 2rem; color: #666;">
        Sorry, that page doesn't exist.
      </p>
      
      <p style="margin-bottom: 2rem;">
        <a href="/" style="color: #0066cc; text-decoration: none; font-weight: 500;">
          ← Back to Home
        </a>
      </p>

      <h2 style="font-size: 1.2rem; margin-top: 3rem; margin-bottom: 1.5rem;">
        Looking for an appeal template?
      </h2>
      <ul style="list-style: none; padding: 0; display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem;">
        <li>
          <a href="/heathrow-drop-off-charge-appeal.astro" style="color: #0066cc;">Heathrow</a>
        </li>
        <li>
          <a href="/gatwick-drop-off-charge-appeal.astro" style="color: #0066cc;">Gatwick</a>
        </li>
        <li>
          <a href="/stansted-drop-off-charge-appeal.astro" style="color: #0066cc;">Stansted</a>
        </li>
        <li>
          <a href="/luton-drop-off-charge-appeal.astro" style="color: #0066cc;">Luton</a>
        </li>
      </ul>
    </div>
  </main>
</BaseLayout>

<style>
  main {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: #333;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }
  }
</style>
