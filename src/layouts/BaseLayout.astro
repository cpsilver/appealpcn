---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  currentPage?: string;
  schema?: object | object[];
}

const { title, description, canonical, currentPage, schema } = Astro.props;

const nav = [
  { href: '/heathrow-drop-off-charge-appeal/', label: 'Heathrow', key: 'heathrow' },
  { href: '/gatwick-drop-off-charge-appeal/',  label: 'Gatwick',  key: 'gatwick'  },
  { href: '/stansted-drop-off-charge-appeal/', label: 'Stansted', key: 'stansted' },
  { href: '/luton-drop-off-charge-appeal/',    label: 'Luton',    key: 'luton'    },
];

const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonical} />
  {schemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
  <!--
    Google AdSense — uncomment and replace with your publisher ID once approved:
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
  -->
</head>
<body>

  <header class="site-header">
    <div class="wrap">
      <a class="logo" href="/">Appeal<em>AirportPCN</em>.co.uk</a>
      <nav class="header-nav">
        {nav.map(({ href, label, key }) => (
          <a href={href} class={currentPage === key ? 'active' : ''}>{label}</a>
        ))}
        <a
          href="https://ko-fi.com/"
          class="donate-btn"
          target="_blank"
          rel="noopener noreferrer"
        >☕ Support us</a>
      </nav>
    </div>
  </header>

  <slot />

  <footer class="site-footer">
    <div class="wrap">
      <p>© {new Date().getFullYear()} AppealAirportPCN.co.uk — Free parking appeal templates for UK drivers</p>
      <p style="margin-top:.5rem">
        <a href="/privacy/">Privacy policy</a>
        <a href="/contact/">Contact</a>
        <a href="/popla-guide/">POPLA guide</a>
        <a href="https://ko-fi.com/" target="_blank" rel="noopener noreferrer">Support this site</a>
      </p>
    </div>
  </footer>

</body>
</html>
