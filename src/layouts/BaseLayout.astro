---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  currentPage?: string;
  schema?: object | object[];
}

const { title, description, canonical, currentPage, schema } = Astro.props;

const airports = [
  { href: '/heathrow-drop-off-charge-appeal/', label: 'Heathrow', key: 'heathrow' },
  { href: '/gatwick-drop-off-charge-appeal/',  label: 'Gatwick',  key: 'gatwick'  },
  { href: '/stansted-drop-off-charge-appeal/', label: 'Stansted', key: 'stansted' },
  { href: '/luton-drop-off-charge-appeal/',    label: 'Luton',    key: 'luton'    },
];

const kofi = "https://ko-fi.com/appealairportpcn";
const defaultOrg = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "AppealAirportPCN.co.uk",
  "url": "https://appealairportpcn.co.uk",
  "logo": "https://appealairportpcn.co.uk/android-chrome-512x512.png"
};

const schemas = schema ? (Array.isArray(schema) ? [...schema, defaultOrg] : [schema, defaultOrg]) : [defaultOrg];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content="https://appealairportpcn.co.uk/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://appealairportpcn.co.uk/og-image.jpg" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  {schemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7045811210154369"
     crossorigin="anonymous"></script>
<link rel="icon" href="/favicon.ico" />

</head>
<body>

  <header class="site-header">
    <div class="wrap header-wrap">
      <a class="logo" href="/">Appeal<em>AirportPCN</em>.co.uk</a>

      <!-- DESKTOP NAV: Airports hover dropdown, Blog link, Support button -->
      <nav class="desktop-nav" aria-label="Main navigation">
        <div class="nav-dropdown" id="nav-dropdown">
          <button class="nav-dropdown-btn" aria-haspopup="true" aria-expanded="false" id="nav-dropdown-btn">
            Airports
            <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="nav-dropdown-menu" id="nav-dropdown-menu" role="menu">
            {airports.map(({ href, label, key }) => (
              <a href={href} class={currentPage === key ? 'active' : ''} role="menuitem">{label}</a>
            ))}
          </div>
        </div>
        <a href="/blog/" class={currentPage === 'blog' ? 'nav-link active' : 'nav-link'}>Why It Works</a>
        <a href="/about/" class={currentPage === 'about' ? 'nav-link active' : 'nav-link'}>About</a>
        <a href={kofi} class="donate-btn" target="_blank" rel="noopener noreferrer">☕ Support us</a>
      </nav>

      <!-- MOBILE HAMBURGER -->
      <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Open menu" aria-expanded="false">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" id="icon-open">
          <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" id="icon-close" style="display:none">
          <path d="M5 5l12 12M17 5L5 17" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- MOBILE DRAWER -->
    <div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
      <p class="mobile-drawer-label">Airports</p>
      {airports.map(({ href, label }) => (
        <a href={href} class="mobile-drawer-link">{label}</a>
      ))}
      <!-- Blog + Support as a button row -->
      <div class="mobile-drawer-actions">
        <a href="/blog/" class="mobile-action-btn mobile-action-blog">Why It Works</a>
        <a href="/about/" class="mobile-action-btn mobile-action-about">About</a>
        <a href={kofi} class="mobile-action-btn mobile-action-support" target="_blank" rel="noopener noreferrer">☕ Support us</a>
      </div>
    </div>
  </header>

  <slot />

  <footer class="site-footer">
    <div class="wrap">
      <p>© {new Date().getFullYear()} AppealAirportPCN.co.uk — Free parking appeal templates for UK drivers</p>
      <p style="margin-top:.5rem">
        <a href="/privacy/">Privacy policy</a>
        <a href="/contact/">Contact</a>
        <a href="/about/">About</a>
        <a href="/blog/">Why It Works</a>
        <a href={kofi} target="_blank" rel="noopener noreferrer">Support this site</a>
      </p>
    </div>
  </footer>

</body>
</html>

<script>
  // ── Mobile menu toggle ──
  const menuBtn   = document.getElementById('mobile-menu-btn')!;
  const drawer    = document.getElementById('mobile-drawer')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  function closeDrawer() {
    drawer.classList.remove('open');
    menuBtn.setAttribute('aria-expanded', 'false');
    drawer.setAttribute('aria-hidden', 'true');
    iconOpen.style.display  = '';
    iconClose.style.display = 'none';
  }

  menuBtn.addEventListener('click', () => {
    const isOpen = drawer.classList.toggle('open');
    menuBtn.setAttribute('aria-expanded', String(isOpen));
    drawer.setAttribute('aria-hidden', String(!isOpen));
    iconOpen.style.display  = isOpen ? 'none' : '';
    iconClose.style.display = isOpen ? ''     : 'none';
  });

  drawer.querySelectorAll('a').forEach(link => link.addEventListener('click', closeDrawer));

  // ── Desktop dropdown — open on hover, keep open while cursor inside ──
  const navDropdown     = document.getElementById('nav-dropdown')!;
  const navDropdownBtn  = document.getElementById('nav-dropdown-btn')!;
  const navDropdownMenu = document.getElementById('nav-dropdown-menu')!;
  let hoverTimeout: ReturnType<typeof setTimeout>;

  function openMenu()  {
    clearTimeout(hoverTimeout);
    navDropdownMenu.classList.add('open');
    navDropdownBtn.setAttribute('aria-expanded', 'true');
  }
  function scheduleClose() {
    hoverTimeout = setTimeout(() => {
      navDropdownMenu.classList.remove('open');
      navDropdownBtn.setAttribute('aria-expanded', 'false');
    }, 120); // small delay so cursor can move from button into menu
  }

  navDropdown.addEventListener('mouseenter', openMenu);
  navDropdown.addEventListener('mouseleave', scheduleClose);

  // Also allow click/keyboard for accessibility
  navDropdownBtn.addEventListener('click', () => {
    const open = navDropdownMenu.classList.toggle('open');
    navDropdownBtn.setAttribute('aria-expanded', String(open));
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!navDropdown.contains(e.target as Node)) {
      navDropdownMenu.classList.remove('open');
      navDropdownBtn.setAttribute('aria-expanded', 'false');
    }
  });
</script>
